@using RcloneFileWatcherCore.DTO
@using RcloneFileWatcherCore.Logic.Rclone
@inject Loc L

@if (Command is not null)
{
    <div class="form-grid">
        <label>
            <span class="lbl">@L["cfg.rclonePath"] <Hint Text="@L["cfg.h.rclonePath"]" /></span>
            <input @bind="Command.RclonePath" />
        </label>
        <label>
            <span class="lbl">@L["cfg.cmdCommand"] <Hint Text="@L["cfg.cmdCommand.h"]" /></span>
            <select @bind="Command.Command">
                <option value="sync">sync</option>
                <option value="copy">copy</option>
                <option value="move">move</option>
            </select>
        </label>
        <label>
            <span class="lbl">@L["cfg.cmdSource"] <Hint Text="@L["cfg.cmdSource.h"]" /></span>
            <input @bind="Command.Source" />
        </label>
        <label>
            <span class="lbl">@L["cfg.cmdDest"] <Hint Text="@L["cfg.cmdDest.h"]" /></span>
            <input @bind="Command.Destination" />
        </label>
        <label>
            <span class="lbl">--config <Hint Text="@L["cfg.h.config"]" /></span>
            <input @bind="Command.ConfigFile" />
        </label>
        <label>
            <span class="lbl">--bwlimit <Hint Text="@L["cfg.h.bwlimit"]" /></span>
            <input @bind="Command.BwLimit" />
        </label>
        <label>
            <span class="lbl">--transfers <Hint Text="@L["cfg.h.transfers"]" /></span>
            <input type="number" min="0" @bind="Command.Transfers" />
        </label>
        <label>
            <span class="lbl">--checkers <Hint Text="@L["cfg.h.checkers"]" /></span>
            <input type="number" min="0" @bind="Command.Checkers" />
        </label>
        <label>
            <span class="lbl">--retries <Hint Text="@L["cfg.h.retries"]" /></span>
            <input type="number" min="0" @bind="Command.Retries" />
        </label>
        <label>
            <span class="lbl">--retries-sleep <Hint Text="@L["cfg.h.retriesSleep"]" /></span>
            <input @bind="Command.RetriesSleep" />
        </label>
        <label>
            <span class="lbl">--backup-dir <Hint Text="@L["cfg.h.backupDir"]" /></span>
            <input @bind="Command.BackupDir" />
        </label>
        <label>
            <span class="lbl">--suffix <Hint Text="@L["cfg.h.suffix"]" /></span>
            <input @bind="Command.Suffix" />
        </label>
        <label>
            <span class="lbl">--log-file <Hint Text="@L["cfg.h.logFile"]" /></span>
            <input @bind="Command.LogFile" />
        </label>
        <label>
            <span class="lbl">--log-level <Hint Text="@L["cfg.h.logLevel"]" /></span>
            <input @bind="Command.LogLevel" />
        </label>
    </div>
    <div class="form-grid">
        @if (ShowIncludeFrom)
        {
            <label class="checkbox">
                <input type="checkbox" @bind="Command.IncludeFrom" @bind:after="OnIncludeFromChanged" /> @L["cfg.includeFromInject"] <Hint Text="@L["cfg.includeFromInject.h"]" />
            </label>
            <label class="checkbox">
                <input type="checkbox" @bind="Command.IncludeFromStdin" disabled="@(!Command.IncludeFrom)" /> @L["cfg.includeFromStdin"] <Hint Text="@L["cfg.includeFromStdin.h"]" />
            </label>
        }
        <label class="checkbox">
            <input type="checkbox" @bind="Command.CreateEmptySrcDirs" /> --create-empty-src-dirs <Hint Text="@L["cfg.h.createEmptySrcDirs"]" />
        </label>
        <label class="checkbox">
            <input type="checkbox" @bind="Command.UseMmap" /> --use-mmap <Hint Text="@L["cfg.h.useMmap"]" />
        </label>
        <label class="checkbox">
            <input type="checkbox" @bind="Command.FastList" /> --fast-list <Hint Text="@L["cfg.h.fastList"]" />
        </label>
        <label class="checkbox">
            <input type="checkbox" @bind="Command.Update" /> --update <Hint Text="@L["cfg.h.update"]" />
        </label>
        <label class="checkbox">
            <input type="checkbox" @bind="Command.DryRun" /> --dry-run <Hint Text="@L["cfg.h.dryRun"]" />
        </label>
    </div>
    <label>
        <span class="lbl">@L["cfg.extraArgs"] <Hint Text="@L["cfg.extraArgs.h"]" /></span>
        <textarea rows="2" @bind="Command.ExtraArgs"></textarea>
    </label>
    <div class="cmd-preview">
        <span class="muted">@L["cfg.preview"]</span>
        <code class="cmd-line">@RcloneCommandBuilder.BuildPreview(Command, PreviewIncludeFrom)</code>
        <span class="muted">@L["cfg.runtimeVars"]
            <code>{datetime}</code> <code>{date}</code> <code>{time}</code> <code>{year}</code></span>
    </div>
}

@code {
    [Parameter] public RcloneCommandDTO Command { get; set; }

    /// <summary>Path shown in the preview when the filter comes from a file (per-path file mode).
    /// Null for full sync (no --include-from).</summary>
    [Parameter] public string IncludeFromPath { get; set; }

    /// <summary>Show the --include-from / stdin toggles (per-path live sync). Off for full sync.</summary>
    [Parameter] public bool ShowIncludeFrom { get; set; } = true;

    private string PreviewIncludeFrom =>
        ShowIncludeFrom && Command.IncludeFrom && Command.IncludeFromStdin ? "-" : IncludeFromPath;

    // Clear the (now-irrelevant) stdin flag when --include-from injection is turned off, so a
    // disabled option isn't silently persisted as true.
    private void OnIncludeFromChanged()
    {
        if (!Command.IncludeFrom)
            Command.IncludeFromStdin = false;
    }
}
