@* Small info icon that shows an explanatory tooltip on hover/focus (native title). *@
@if (!string.IsNullOrWhiteSpace(Text))
{
    <span class="hint" title="@Text" tabindex="0" role="img" aria-label="@Text"><Icon Name="info" Size="15" /></span>
}

@code {
    [Parameter] public string Text { get; set; }
}
