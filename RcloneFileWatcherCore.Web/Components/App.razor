<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <script>
        (function () {
            try {
                if (localStorage.getItem('rfw-theme') === 'light') {
                    document.documentElement.setAttribute('data-theme', 'light');
                }
            } catch (e) { }
        })();
        window.rfwDownloadText = function (filename, text) {
            try {
                var blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
                var url = URL.createObjectURL(blob);
                var a = document.createElement('a');
                a.href = url;
                a.download = filename;
                document.body.appendChild(a);
                a.click();
                a.remove();
                URL.revokeObjectURL(url);
            } catch (e) { }
        };
        window.rfwToggleTheme = function () {
            var light = document.documentElement.getAttribute('data-theme') === 'light';
            if (light) {
                document.documentElement.removeAttribute('data-theme');
                try { localStorage.setItem('rfw-theme', 'dark'); } catch (e) { }
            } else {
                document.documentElement.setAttribute('data-theme', 'light');
                try { localStorage.setItem('rfw-theme', 'light'); } catch (e) { }
            }
        };
    </script>
    <link rel="stylesheet" href="app.css" />
    <link rel="icon" href="data:," />
    <title>RcloneFileWatcher</title>
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script>
        window.rfwScrollToBottom = (id) => {
            const el = document.getElementById(id);
            if (el) { el.scrollTop = el.scrollHeight; }
        };
        // Close the mobile nav drawer (CSS checkbox hack) after any sidebar link/button is
        // clicked - scoped to the .sidebar container (owned by MainLayout) so new drawer entries
        // keep working without touching this code. Delegated so it survives Blazor's
        // enhanced-navigation DOM patches. Pure first-party JS - independent of the SignalR
        // circuit, so it keeps working even if interactivity is unavailable.
        function rfwCloseNav() {
            var cb = document.getElementById('rfwNavToggle');
            if (cb) { cb.checked = false; }
        }
        document.addEventListener('click', function (e) {
            if (e.target.closest('.sidebar a, .sidebar button')) { rfwCloseNav(); }
        });
        // Reset the drawer when the layout switches to desktop (where the checkbox has no visible
        // effect), so it doesn't slide back open with its scrim when the viewport shrinks again.
        window.matchMedia('(min-width: 769px)').addEventListener('change', function (e) {
            if (e.matches) { rfwCloseNav(); }
        });
    </script>
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
