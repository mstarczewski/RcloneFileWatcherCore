@page "/"
@rendermode InteractiveServer
@using System.Threading
@using System.Linq
@using RcloneFileWatcherCore.App
@using RcloneFileWatcherCore.Config
@using RcloneFileWatcherCore.DTO
@using RcloneFileWatcherCore.Enums
@using RcloneFileWatcherCore.Status
@implements IDisposable
@inject IStatusService StatusService
@inject IRuntimeController Controller
@inject IConfigService ConfigService
@inject Loc L

<PageTitle>@L["nav.dashboard"] — RcloneFileWatcher</PageTitle>

<div class="page-head">
    <h1>@L["nav.dashboard"]</h1>
    <span class="live-dot" title="@L["nav.dashboard"]"></span>
</div>

@if (DryRunActive())
{
    <div class="alert alert-warn">
        <Icon Name="warning" />
        <span>@L["dash.dryRunWarning"]</span>
    </div>
}

@if (DisabledCount() is var disabled && disabled > 0)
{
    <div class="alert alert-warn">
        <Icon Name="warning" />
        <span>@L.F("dash.disabledWarning", disabled)</span>
    </div>
}

@if (_status is null)
{
    <p>@L["dash.loading"]</p>
}
else
{
    <div class="cards">
        <div class="card">
            <div class="card-label">@L["dash.watcher"]</div>
            <div class="card-value @(_status.WatcherRunning ? "ok" : "warn")">
                <Icon Name="@(_status.WatcherRunning ? "success" : "warning")" Size="20" />
                @(_status.WatcherRunning ? L["dash.running"] : L["dash.stopped"])
            </div>
        </div>
        <div class="card">
            <div class="card-label">@L["dash.queued"]</div>
            <div class="card-value">@_status.PendingChanges</div>
        </div>
        <div class="card">
            <div class="card-label">@L["dash.watchedPaths"]</div>
            <div class="card-value">@(_status.WatchedPaths?.Count ?? 0)</div>
        </div>
        <div class="card">
            <div class="card-label">@L["dash.startedUtc"]</div>
            <div class="card-value small">@(_status.StartedAtUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</div>
        </div>
    </div>

    <p class="muted">@_status.Version</p>

    @if (_message is not null)
    {
        <div class="alert @(_success ? "alert-ok" : "alert-err")">
            <Icon Name="@(_success ? "success" : "error")" />
            <span>@_message</span>
        </div>
    }

    <div class="actions">
        @{
            var rcloneBusy = _jobBusy || _status.RcloneRunning;
        }
        @if (_status.WatcherRunning)
        {
            <button class="btn btn-secondary" @onclick="StopWatcher" disabled="@rcloneBusy"><Icon Name="stop" Size="16" /> @L["dash.stopWatcher"]</button>
        }
        else
        {
            <button class="btn" @onclick="StartWatcher"><Icon Name="play" Size="16" /> @L["dash.startWatcher"]</button>
        }
        <button class="btn" @onclick="SyncNow" disabled="@(!_status.WatcherRunning || rcloneBusy)"><Icon Name="refresh" Size="16" /> @L["dash.syncNow"]</button>
        <button class="btn" @onclick="FullSyncNow" disabled="@(!_status.WatcherRunning || rcloneBusy)"><Icon Name="refresh" Size="16" /> @L["dash.fullSync"]</button>
        @if (rcloneBusy)
        {
            <button class="btn btn-abort" @onclick="StopRclone"><Icon Name="stop" Size="16" /> @L["dash.stopRclone"]</button>
        }
    </div>

    @if (_status.WatchedPaths is { Count: > 0 })
    {
        <h2>@L["dash.watchedDirs"]</h2>
        <ul class="path-list">
            @foreach (var path in _status.WatchedPaths)
            {
                <li><code>@path</code></li>
            }
        </ul>
    }
    else
    {
        <p class="muted">@L["dash.noPaths"]</p>
    }
}

@code {
    private AppStatus _status;
    private PeriodicTimer _timer;
    private CancellationTokenSource _cts;
    private string _message;
    private bool _success;

    // True when any managed rclone command (per-path or full sync) has --dry-run enabled, so
    // nothing it runs will actually transfer — surfaced as a dashboard warning.
    private bool DryRunActive()
    {
        var cfg = ConfigService.Current;
        if (cfg is null)
            return false;

        var pathDryRun = cfg.Path?.Any(p => p.SyncMode == SyncMode.Managed && p.RcloneCommand?.DryRun == true) ?? false;
        var fullDryRun = cfg.FullSyncMode == SyncMode.Managed
            && (cfg.FullSyncCommands?.Any(c => c?.DryRun == true) ?? false);
        return pathDryRun || fullDryRun;
    }

    // Number of disabled syncs (watched paths + managed full-sync commands) kept in the config
    // but not running — surfaced as a dashboard warning.
    private int DisabledCount()
    {
        var cfg = ConfigService.Current;
        if (cfg is null)
            return 0;

        var paths = cfg.Path?.Count(p => p is { Enabled: false }) ?? 0;
        var full = cfg.FullSyncMode == SyncMode.Managed
            ? (cfg.FullSyncCommands?.Count(c => c is { Enabled: false }) ?? 0)
            : 0;
        return paths + full;
    }

    protected override void OnInitialized()
    {
        _status = StatusService.GetStatus();
        _cts = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        _ = RunLoopAsync(_cts.Token);
    }

    private async Task RunLoopAsync(CancellationToken ct)
    {
        try
        {
            while (await _timer.WaitForNextTickAsync(ct))
            {
                _status = StatusService.GetStatus();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // component disposed
        }
    }

    private void StartWatcher()
    {
        try
        {
            Controller.Start();
            _message = L["dash.msgStarted"];
            _success = true;
        }
        catch (Exception ex)
        {
            _message = L.F("dash.msgStartFailed", ex.Message);
            _success = false;
        }
        _status = StatusService.GetStatus();
    }

    private void StopWatcher()
    {
        Controller.Stop();
        _message = L["dash.msgStopped"];
        _success = true;
        _status = StatusService.GetStatus();
    }

    private bool _jobBusy;
    private bool _stopRequested;

    private Task SyncNow() => RunManualJob(() => Controller.SyncNowAsync());

    private Task FullSyncNow() => RunManualJob(() => Controller.FullSyncNowAsync());

    private async Task RunManualJob(Func<Task<bool>> action)
    {
        if (_jobBusy)
            return;

        _jobBusy = true;
        _stopRequested = false;
        _message = L["dash.jobRunning"];
        _success = true;
        try
        {
            var ok = await action();
            if (_stopRequested)
            {
                _message = L["dash.rcloneStopped"];
                _success = true;
            }
            else
            {
                _message = ok ? L["dash.jobDone"] : L["dash.jobFailed"];
                _success = ok;
            }
        }
        catch (Exception ex)
        {
            _message = ex.Message;
            _success = false;
        }
        finally
        {
            _jobBusy = false;
            _status = StatusService.GetStatus();
        }
    }

    private void StopRclone()
    {
        _stopRequested = true;
        Controller.StopRclone();
        _message = L["dash.rcloneStopping"];
        _success = true;
        _status = StatusService.GetStatus();
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _timer?.Dispose();
        _cts?.Dispose();
    }
}
