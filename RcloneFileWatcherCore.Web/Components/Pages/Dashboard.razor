@page "/"
@rendermode InteractiveServer
@using System.Threading
@using RcloneFileWatcherCore.App
@using RcloneFileWatcherCore.Status
@implements IDisposable
@inject IStatusService StatusService
@inject IRuntimeController Controller

<PageTitle>Pulpit — RcloneFileWatcher</PageTitle>

<div class="page-head">
    <h1>Pulpit</h1>
    <span class="live-dot" title="Aktualizacja na żywo"></span>
</div>

@if (_status is null)
{
    <p>Ładowanie statusu…</p>
}
else
{
    <div class="cards">
        <div class="card">
            <div class="card-label">Watcher</div>
            <div class="card-value @(_status.WatcherRunning ? "ok" : "warn")">
                @(_status.WatcherRunning ? "Działa" : "Zatrzymany")
            </div>
        </div>
        <div class="card">
            <div class="card-label">Zmiany w kolejce</div>
            <div class="card-value">@_status.PendingChanges</div>
        </div>
        <div class="card">
            <div class="card-label">Obserwowane ścieżki</div>
            <div class="card-value">@(_status.WatchedPaths?.Count ?? 0)</div>
        </div>
        <div class="card">
            <div class="card-label">Uruchomiono (UTC)</div>
            <div class="card-value small">@(_status.StartedAtUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</div>
        </div>
    </div>

    <p class="muted">@_status.Version</p>

    @if (_message is not null)
    {
        <div class="alert @(_success ? "alert-ok" : "alert-err")">@_message</div>
    }

    <div class="actions">
        @if (_status.WatcherRunning)
        {
            <button class="btn btn-secondary" @onclick="StopWatcher">Zatrzymaj watcher</button>
        }
        else
        {
            <button class="btn" @onclick="StartWatcher">Uruchom watcher</button>
        }
        <button class="btn" @onclick="SyncNow" disabled="@(!_status.WatcherRunning)">Synchronizuj teraz</button>
        <button class="btn" @onclick="FullSyncNow" disabled="@(!_status.WatcherRunning)">Pełna synchronizacja</button>
    </div>

    @if (_status.WatchedPaths is { Count: > 0 })
    {
        <h2>Obserwowane katalogi</h2>
        <ul class="path-list">
            @foreach (var path in _status.WatchedPaths)
            {
                <li><code>@path</code></li>
            }
        </ul>
    }
    else
    {
        <p class="muted">Brak skonfigurowanych ścieżek. Dodaj je w sekcji
            <NavLink href="config">Konfiguracja</NavLink>.</p>
    }
}

@code {
    private AppStatus _status;
    private PeriodicTimer _timer;
    private CancellationTokenSource _cts;
    private string _message;
    private bool _success;

    private void StartWatcher()
    {
        try
        {
            Controller.Start();
            _message = "Watcher uruchomiony.";
            _success = true;
        }
        catch (Exception ex)
        {
            _message = $"Nie udało się uruchomić: {ex.Message}";
            _success = false;
        }
        _status = StatusService.GetStatus();
    }

    private void StopWatcher()
    {
        Controller.Stop();
        _message = "Watcher zatrzymany.";
        _success = true;
        _status = StatusService.GetStatus();
    }

    private void SyncNow()
    {
        Controller.SyncNow();
        _message = "Zlecono synchronizację (sprawdź Logi).";
        _success = true;
    }

    private void FullSyncNow()
    {
        Controller.FullSyncNow();
        _message = "Zlecono pełną synchronizację (sprawdź Logi).";
        _success = true;
    }

    protected override void OnInitialized()
    {
        _status = StatusService.GetStatus();
        _cts = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        _ = RunLoopAsync(_cts.Token);
    }

    private async Task RunLoopAsync(CancellationToken ct)
    {
        try
        {
            while (await _timer.WaitForNextTickAsync(ct))
            {
                _status = StatusService.GetStatus();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // component disposed
        }
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _timer?.Dispose();
        _cts?.Dispose();
    }
}
