@page "/config"
@rendermode InteractiveServer
@using System.Collections.Generic
@using System.Linq
@using System.IO
@using System.Text.Json
@using RcloneFileWatcherCore.Config
@using RcloneFileWatcherCore.DTO
@using RcloneFileWatcherCore.Enums
@using RcloneFileWatcherCore.Logic.Rclone
@using Microsoft.JSInterop
@inject IConfigService ConfigService
@inject IJSRuntime JS
@inject Loc L

<PageTitle>@L["nav.config"] — RcloneFileWatcher</PageTitle>

<h1>@L["nav.config"]</h1>

<p class="muted">@L.F("cfg.intro", ConfigService.FilePath)</p>

@if (_message is not null)
{
    <div class="alert @(_success ? "alert-ok" : "alert-err")">
        <Icon Name="@(_success ? "success" : "error")" />
        <span>@_message</span>
    </div>
}

@if (_errors.Count > 0)
{
    <div class="alert alert-err">
        <Icon Name="warning" />
        <ul>
            @foreach (var e in _errors)
            {
                <li>@e</li>
            }
        </ul>
    </div>
}

@if (_model is not null)
{
    <div class="tabs">
        <button class="tab @(_activeTab == Tab.General ? "active" : "")" @onclick="() => _activeTab = Tab.General">@L["cfg.tabGeneral"]</button>
        <button class="tab @(_activeTab == Tab.FullSync ? "active" : "")" @onclick="() => _activeTab = Tab.FullSync">@(_model.FullSyncMode == SyncMode.Managed ? L.F("cfg.tabFullSyncN", _model.FullSyncCommands.Count) : L["cfg.tabFullSync"])</button>
        <button class="tab @(_activeTab == Tab.Paths ? "active" : "")" @onclick="() => _activeTab = Tab.Paths">@L.F("cfg.tabPaths", _model.Path.Count)</button>
    </div>

    @if (_activeTab == Tab.General)
    {
        <section class="form-section">
            <h2>@L["cfg.general"]</h2>
            <div class="field">
                <span class="field-label">@L["cfg.logLevel"] <Hint Text="@L["cfg.logLevel.h"]" /></span>
                <div class="checkbox-row">
                    @foreach (var lvl in LogLevels)
                    {
                        <label class="checkbox">
                            <input type="checkbox" checked="@_selectedLevels.Contains(lvl)"
                                   @onchange="e => ToggleLevel(lvl, (bool?)e.Value ?? false)" /> @lvl
                        </label>
                    }
                </div>
                <span class="muted">@L["cfg.logLevelHint"]</span>
            </div>
            <div class="form-grid">
                <label>
                    <span class="lbl">@L["cfg.logPath"] <Hint Text="@L["cfg.logPath.h"]" /></span>
                    <input @bind="_model.LogPath" />
                </label>
                <label>
                    <span class="lbl">@L["cfg.syncInterval"] <Hint Text="@L["cfg.syncInterval.h"]" /></span>
                    <input type="number" min="1" @bind="_model.SyncIntervalSeconds" />
                </label>
            </div>
        </section>

        <section class="form-section">
            <h2>@L["cfg.autoUpdate"]</h2>
            <div class="form-grid">
                <label class="checkbox">
                    <input type="checkbox" @bind="_model.UpdateRclone.Update" />
                    @L["cfg.enableAutoUpdate"] <Hint Text="@L["cfg.enableAutoUpdate.h"]" />
                </label>
                <label>
                    <span class="lbl">@L["cfg.rclonePath"] <Hint Text="@L["cfg.rclonePath.h"]" /></span>
                    <input @bind="_model.UpdateRclone.RclonePath" />
                </label>
                <label>
                    <span class="lbl">@L["cfg.checkEvery"] <Hint Text="@L["cfg.checkEvery.h"]" /></span>
                    <input type="number" min="0" @bind="_model.UpdateRclone.CheckUpdateHours" />
                </label>
            </div>
        </section>
    }

    @if (_activeTab == Tab.FullSync)
    {
        <section class="form-section">
            <h2>@L["cfg.fullSyncTitle"]</h2>
            <div class="form-grid">
                <label class="checkbox">
                    <input type="checkbox" @bind="_model.RunOneTimeFullStartupSync" />
                    @L["cfg.fullSyncStartup"] <Hint Text="@L["cfg.fullSyncStartup.h"]" />
                </label>
                <label>
                    <span class="lbl">@L["cfg.fullSyncDaily"] <Hint Text="@L["cfg.fullSyncDaily.h"]" /></span>
                    <input @bind="_model.RunStartupScriptEveryDayAt" placeholder="05:30" />
                </label>
                <label>
                    <span class="lbl">@L["cfg.runMode"] <Hint Text="@L["cfg.runMode.h"]" /></span>
                    <select @bind="_model.FullSyncMode">
                        <option value="@SyncMode.Script">@L["cfg.modeScript"]</option>
                        <option value="@SyncMode.Managed">@L["cfg.modeManaged"]</option>
                    </select>
                </label>
            </div>

            @if (_model.FullSyncMode == SyncMode.Script)
            {
                <label>
                    <span class="lbl">@L["cfg.fullSyncScript"] <Hint Text="@L["cfg.fullSyncScript.h"]" /></span>
                    <input @bind="_model.RunOneTimeFullStartupSyncBatch" />
                </label>
                <button class="btn btn-sm" @onclick="ImportFullSyncFromScript">@L["cfg.importThisScript"]</button>
            }
            else
            {
                <div class="section-head">
                    <h3 class="subhead">@L.F("cfg.fullSyncCommands", _model.FullSyncCommands.Count)</h3>
                    <button class="btn btn-sm" @onclick="AddFullSyncCommand">@L["cfg.addCommand"]</button>
                </div>
                @if (_model.FullSyncCommands.Count == 0)
                {
                    <p class="muted">@L["cfg.noFullSyncCommands"]</p>
                }
                @for (var i = 0; i < _model.FullSyncCommands.Count; i++)
                {
                    var ci = i;
                    <div class="path-card">
                        <div class="path-card-head">
                            <strong>@L.F("cfg.commandN", ci + 1)</strong>
                            <button class="btn btn-sm btn-danger" @onclick="() => RemoveFullSyncCommand(ci)">@L["cfg.remove"]</button>
                        </div>
                        <RcloneCommandEditor Command="_model.FullSyncCommands[ci]" ShowIncludeFrom="false" />
                    </div>
                }
            }
        </section>
    }

    @if (_activeTab == Tab.Paths)
    {
        <section class="form-section">
            <div class="section-head">
                <h2>@L.F("cfg.watchedPaths", _model.Path.Count)</h2>
                <div class="section-head-actions">
                    <button class="btn btn-sm btn-secondary" @onclick="ImportAllFromScripts">@L["cfg.importScripts"]</button>
                    <button class="btn btn-sm" @onclick="AddPath">@L["cfg.addPath"]</button>
                </div>
            </div>

            @if (_model.Path.Count == 0)
            {
                <p class="muted">@L["cfg.noPaths"]</p>
            }

            @for (var i = 0; i < _model.Path.Count; i++)
            {
                var index = i;
                <div class="path-card">
                    <div class="path-card-head">
                        <strong>@L.F("cfg.pathN", index + 1)</strong>
                        <button class="btn btn-sm btn-danger" @onclick="() => RemovePath(index)">@L["cfg.remove"]</button>
                    </div>
                    <div class="form-grid">
                        <label>
                            <span class="lbl">@L["cfg.watchDir"] <Hint Text="@L["cfg.watchDir.h"]" /></span>
                            <input @bind="_model.Path[index].WatchingPath" />
                        </label>
                        <label>
                            <span class="lbl">@L["cfg.includeFromFile"] <Hint Text="@L["cfg.includeFromFile.h"]" /></span>
                            <input @bind="_model.Path[index].RcloneFilesFromPath" />
                        </label>
                        <label>
                            <span class="lbl">@L["cfg.runMode"] <Hint Text="@L["cfg.runMode.h"]" /></span>
                            <select @bind="_model.Path[index].SyncMode" @bind:after="() => OnModeChanged(index)">
                                <option value="@SyncMode.Script">@L["cfg.modeScript"]</option>
                                <option value="@SyncMode.Managed">@L["cfg.modeManaged"]</option>
                            </select>
                        </label>
                    </div>

                    @if (_model.Path[index].SyncMode == SyncMode.Script)
                    {
                        <label>
                            <span class="lbl">@L["cfg.scriptFile"] <Hint Text="@L["cfg.scriptFile.h"]" /></span>
                            <input @bind="_model.Path[index].RcloneBatch" />
                        </label>
                        <button class="btn btn-sm btn-secondary" @onclick="() => ImportFromScript(index)">
                            @L["cfg.importThisScript"]
                        </button>
                    }
                    else
                    {
                        <RcloneCommandEditor Command="GetCommand(index)" IncludeFromPath="@_model.Path[index].RcloneFilesFromPath" />
                    }

                    <label>
                        <span class="lbl">@L["cfg.exclude"] <Hint Text="@L["cfg.exclude.h"]" /></span>
                        <textarea rows="3" @bind="_excludeRaw[index]"></textarea>
                    </label>
                </div>
            }
        </section>
    }

    <div class="actions">
        <button class="btn" @onclick="Save">@L["cfg.save"]</button>
        <button class="btn btn-secondary" @onclick="Reset">@L["cfg.reset"]</button>
    </div>
}

@code {
    private ConfigDTO _model;
    private List<string> _excludeRaw = new();
    private List<string> _errors = new();
    private string _message;
    private bool _success;
    private bool _scrollPending;

    private enum Tab { General, FullSync, Paths }
    private Tab _activeTab = Tab.General;

    protected override void OnInitialized() => LoadFromCurrent();

    // After an action sets a status message (which renders at the top of the page), scroll the
    // window up so the result is visible — the Save/Import buttons sit far below the fold.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_scrollPending)
        {
            _scrollPending = false;
            await JS.InvokeVoidAsync("scrollTo", new { top = 0, behavior = "smooth" });
        }
    }

    private void LoadFromCurrent()
    {
        _model = Clone(ConfigService.Current);
        _model.Path ??= new List<PathDTO>();
        _model.UpdateRclone ??= new UpdateRcloneDTO();
        _model.FullSyncCommands ??= new List<RcloneCommandDTO>();
        _excludeRaw = _model.Path
            .Select(p => string.Join("\n", p.ExcludeContains ?? new List<string>()))
            .ToList();
        _selectedLevels = ParseLevels(_model.LogLevel);
        _errors.Clear();
    }

    private static readonly string[] LogLevels =
        { "Trace", "Debug", "Information", "Warning", "Error", "Critical", "Always" };

    private HashSet<string> _selectedLevels = new(StringComparer.OrdinalIgnoreCase);

    private static HashSet<string> ParseLevels(string value)
    {
        var set = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        if (!string.IsNullOrWhiteSpace(value))
        {
            foreach (var part in value.Split(new[] { '|', ',', ';', ' ' }, StringSplitOptions.RemoveEmptyEntries))
            {
                var canonical = LogLevels.FirstOrDefault(l => string.Equals(l, part.Trim(), StringComparison.OrdinalIgnoreCase));
                if (canonical != null)
                    set.Add(canonical);
            }
        }
        return set;
    }

    private void ToggleLevel(string level, bool on)
    {
        if (on) _selectedLevels.Add(level);
        else _selectedLevels.Remove(level);
        _model.LogLevel = string.Join("|", LogLevels.Where(_selectedLevels.Contains));
    }

    private void AddPath()
    {
        _model.Path.Add(new PathDTO());
        _excludeRaw.Add(string.Empty);
    }

    private void RemovePath(int index)
    {
        _model.Path.RemoveAt(index);
        _excludeRaw.RemoveAt(index);
    }

    private void AddFullSyncCommand()
        => _model.FullSyncCommands.Add(new RcloneCommandDTO { IncludeFrom = false, Command = "sync" });

    private void RemoveFullSyncCommand(int index)
        => _model.FullSyncCommands.RemoveAt(index);

    // Import a full-sync batch file that chains several rclone calls. Each rclone invocation
    // becomes its own managed command, then the mode flips to Managed for review.
    private void ImportFullSyncFromScript()
    {
        _scrollPending = true;
        var batch = _model.RunOneTimeFullStartupSyncBatch;
        if (string.IsNullOrWhiteSpace(batch) || !File.Exists(batch))
        {
            _message = L.F("cfg.scriptNotFound", string.IsNullOrWhiteSpace(batch) ? L["cfg.noPathPlaceholder"] : batch);
            _success = false;
            return;
        }

        try
        {
            var commands = RcloneCommandParser.ParseMany(File.ReadAllText(batch));
            if (commands.Count == 0)
            {
                _message = L.F("cfg.importedFullSyncNone", batch);
                _success = false;
                return;
            }

            foreach (var c in commands)
                c.IncludeFrom = false; // full sync doesn't inject a watched --include-from list
            _model.FullSyncCommands = commands;
            _model.FullSyncMode = SyncMode.Managed;
            _message = L.F("cfg.importedFullSync", commands.Count);
            _success = true;
        }
        catch (Exception ex)
        {
            _message = L.F("cfg.importError", ex.Message);
            _success = false;
        }
    }

    // Lazily create the managed command so the fields/preview can bind even when the loaded
    // config had Managed mode with no command, or right after switching to Managed.
    private RcloneCommandDTO GetCommand(int index)
    {
        var p = _model.Path[index];
        p.RcloneCommand ??= new RcloneCommandDTO { Source = p.WatchingPath };
        return p.RcloneCommand;
    }

    private void OnModeChanged(int index)
    {
        if (_model.Path[index].SyncMode == SyncMode.Managed)
            GetCommand(index);
    }

    private void ImportFromScript(int index)
    {
        _scrollPending = true;
        var batch = _model.Path[index].RcloneBatch;
        if (string.IsNullOrWhiteSpace(batch) || !File.Exists(batch))
        {
            _message = L.F("cfg.scriptNotFound", string.IsNullOrWhiteSpace(batch) ? L["cfg.noPathPlaceholder"] : batch);
            _success = false;
            return;
        }

        try
        {
            _model.Path[index].RcloneCommand = RcloneCommandParser.Parse(File.ReadAllText(batch));
            _model.Path[index].SyncMode = SyncMode.Managed;
            _message = L.F("cfg.importedOne", index + 1);
            _success = true;
        }
        catch (Exception ex)
        {
            _message = L.F("cfg.importError", ex.Message);
            _success = false;
        }
    }

    private void ImportAllFromScripts()
    {
        _scrollPending = true;
        int imported = 0, skipped = 0;
        for (var i = 0; i < _model.Path.Count; i++)
        {
            var batch = _model.Path[i].RcloneBatch;
            if (!string.IsNullOrWhiteSpace(batch) && File.Exists(batch))
            {
                try
                {
                    _model.Path[i].RcloneCommand = RcloneCommandParser.Parse(File.ReadAllText(batch));
                    _model.Path[i].SyncMode = SyncMode.Managed;
                    imported++;
                }
                catch { skipped++; }
            }
            else
            {
                skipped++;
            }
        }

        _message = skipped > 0
            ? L.F("cfg.importedManySkipped", imported, skipped)
            : L.F("cfg.importedMany", imported);
        _success = imported > 0;
    }

    private void Reset()
    {
        _scrollPending = true;
        LoadFromCurrent();
        _message = L["cfg.restored"];
        _success = true;
    }

    private void Save()
    {
        _scrollPending = true;
        // Fold the textarea contents back into ExcludeContains lists.
        for (var i = 0; i < _model.Path.Count; i++)
        {
            _model.Path[i].ExcludeContains = _excludeRaw[i]
                .Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries)
                .Select(s => s.Trim())
                .Where(s => s.Length > 0)
                .ToList();
        }

        if (!Validate())
        {
            _message = L["cfg.notSaved"];
            _success = false;
            return;
        }

        try
        {
            ConfigService.Save(_model);
            LoadFromCurrent();
            _message = L["cfg.savedApplied"];
            _success = true;
        }
        catch (Exception ex)
        {
            _message = L.F("cfg.saveError", ex.Message);
            _success = false;
        }
    }

    private bool Validate()
    {
        _errors.Clear();

        if (_model.SyncIntervalSeconds < 1)
            _errors.Add(L["cfg.vInterval"]);

        if (!string.IsNullOrWhiteSpace(_model.RunStartupScriptEveryDayAt)
            && !TimeSpan.TryParse(_model.RunStartupScriptEveryDayAt, out _))
            _errors.Add(L["cfg.vTime"]);

        // Full sync at startup needs something to run: a script (Script mode) or at least one
        // managed command (Managed mode).
        if (_model.RunOneTimeFullStartupSync)
        {
            if (_model.FullSyncMode == SyncMode.Script && string.IsNullOrWhiteSpace(_model.RunOneTimeFullStartupSyncBatch))
                _errors.Add(L["cfg.vStartupScript"]);
            else if (_model.FullSyncMode == SyncMode.Managed && (_model.FullSyncCommands == null || _model.FullSyncCommands.Count == 0))
                _errors.Add(L["cfg.vFullSyncCommands"]);
        }

        if (_model.UpdateRclone.Update && string.IsNullOrWhiteSpace(_model.UpdateRclone.RclonePath))
            _errors.Add(L["cfg.vRclonePath"]);

        if (_model.UpdateRclone.CheckUpdateHours < 0)
            _errors.Add(L["cfg.vCheckHours"]);

        for (var i = 0; i < _model.Path.Count; i++)
        {
            var p = _model.Path[i];
            if (string.IsNullOrWhiteSpace(p.WatchingPath))
                _errors.Add(L.F("cfg.vWatchDir", i + 1));

            // The --include-from file is only needed for script mode or a managed command that
            // reads the filter from a file (not stdin).
            var needsFile = p.SyncMode == SyncMode.Script
                || (p.RcloneCommand is { IncludeFrom: true, IncludeFromStdin: false });
            if (needsFile && string.IsNullOrWhiteSpace(p.RcloneFilesFromPath))
                _errors.Add(L.F("cfg.vIncludeFrom", i + 1));
        }

        return _errors.Count == 0;
    }

    private static ConfigDTO Clone(ConfigDTO src)
        => JsonSerializer.Deserialize<ConfigDTO>(JsonSerializer.Serialize(src));
}
