@page "/logs"
@rendermode InteractiveServer
@using System.Collections.Generic
@using System.Linq
@using RcloneFileWatcherCore.Infrastructure.Logging
@implements IDisposable
@inject BroadcastLogWriter LogBuffer
@inject IJSRuntime JS
@inject Loc L

<PageTitle>@L["nav.logs"] — RcloneFileWatcher</PageTitle>

<h1>@L["nav.logs"]</h1>

<div class="toolbar">
    <label>
        @L["log.level"]
        <select @bind="_levelFilter" @bind:after="ApplyFilter">
            <option value="">@L["log.all"]</option>
            @foreach (var level in Levels)
            {
                <option value="@level">@level</option>
            }
        </select>
    </label>
    <label class="checkbox">
        <input type="checkbox" @bind="_autoScroll" /> @L["log.autoScroll"]
    </label>
    <span class="spacer"></span>
    <span class="muted">@L.F("log.entries", _filtered.Count, _lines.Count)</span>
    <button class="btn btn-sm" @onclick="Clear">@L["log.clear"]</button>
</div>

<pre class="log-view" id="logView">@(_filtered.Count == 0 ? L["log.noEntries"] : string.Join("\n", _filtered))</pre>

@code {
    private static readonly string[] Levels =
        { "Trace", "Debug", "Information", "Warning", "Error", "Critical", "Always" };

    private const int MaxLines = 1000;

    private readonly List<string> _lines = new();
    private List<string> _filtered = new();
    private string _levelFilter = "";
    private bool _autoScroll = true;

    protected override void OnInitialized()
    {
        _lines.AddRange(LogBuffer.GetRecent());
        ApplyFilter();
        LogBuffer.MessageWritten += OnMessage;
    }

    private void OnMessage(string message)
    {
        _ = InvokeAsync(() =>
        {
            _lines.Add(message);
            if (_lines.Count > MaxLines)
                _lines.RemoveRange(0, _lines.Count - MaxLines);

            if (Matches(message))
                _filtered.Add(message);

            StateHasChanged();
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_autoScroll)
            await JS.InvokeVoidAsync("rfwScrollToBottom", "logView");
    }

    private void ApplyFilter()
    {
        _filtered = _lines.Where(Matches).ToList();
    }

    private bool Matches(string line)
    {
        if (string.IsNullOrEmpty(_levelFilter))
            return true;
        return ExtractLevel(line) == _levelFilter;
    }

    private static string ExtractLevel(string line)
    {
        var open = line.IndexOf('[');
        var close = open >= 0 ? line.IndexOf(']', open + 1) : -1;
        return close > open ? line.Substring(open + 1, close - open - 1) : "";
    }

    private void Clear()
    {
        _lines.Clear();
        _filtered.Clear();
    }

    public void Dispose()
    {
        LogBuffer.MessageWritten -= OnMessage;
    }
}
