@page "/logs"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Collections.Generic
@using System.Linq
@using RcloneFileWatcherCore.Infrastructure.Logging
@implements IDisposable
@inject BroadcastLogWriter LogBuffer
@inject IJSRuntime JS
@inject Loc L

<PageTitle>@L["nav.logs"] — RcloneFileWatcher</PageTitle>

<h1>@L["nav.logs"]</h1>

<div class="toolbar">
    <label>
        @L["log.level"]
        <select @bind="_levelFilter" @bind:after="ApplyFilter">
            <option value="">@L["log.all"]</option>
            @foreach (var level in Loc.LogLevels)
            {
                <option value="@level">@level</option>
            }
        </select>
    </label>
    <label class="checkbox">
        <input type="checkbox" @bind="_autoScroll" /> @L["log.autoScroll"]
    </label>
    <span class="spacer"></span>
    <span class="muted">@L.F("log.entries", _filtered.Count, _lines.Count)</span>
    <button class="btn btn-sm" @onclick="Download" disabled="@(_lines.Count == 0)">@L["log.download"]</button>
    <button class="btn btn-sm" @onclick="Clear">@L["log.clear"]</button>
</div>

<pre class="log-view" id="logView">@(_filtered.Count == 0 ? L["log.noEntries"] : string.Join("\n", _filtered))</pre>

@code {
    private const int MaxLines = 10000;

    // Coalesce re-renders: with a large buffer, joining and diffing the whole <pre> on every
    // incoming line is expensive, so render at most once per this interval under heavy logging.
    private const int RenderIntervalMs = 200;

    private readonly List<string> _lines = new();
    private List<string> _filtered = new();
    private string _levelFilter = "";
    private bool _autoScroll = true;
    private bool _renderQueued;

    protected override void OnInitialized()
    {
        _lines.AddRange(LogBuffer.GetRecent());
        ApplyFilter();
        LogBuffer.MessageWritten += OnMessage;
    }

    private void OnMessage(string message)
    {
        _ = InvokeAsync(() =>
        {
            _lines.Add(message);
            if (_lines.Count > MaxLines)
                _lines.RemoveRange(0, _lines.Count - MaxLines);

            if (Matches(message))
                _filtered.Add(message);

            QueueRender();
        });
    }

    // Render at most once per RenderIntervalMs: messages arriving during the window are batched
    // into a single re-render so a burst of log lines can't swamp the UI/SignalR circuit.
    private void QueueRender()
    {
        if (_renderQueued)
            return;
        _renderQueued = true;
        _ = InvokeAsync(async () =>
        {
            await Task.Delay(RenderIntervalMs);
            _renderQueued = false;
            StateHasChanged();
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_autoScroll)
            return;
        try
        {
            await JS.InvokeVoidAsync("rfwScrollToBottom", "logView");
        }
        catch (JSDisconnectedException)
        {
            // The circuit was torn down (navigation/refresh) before the interop ran — ignore.
        }
    }

    private void ApplyFilter()
    {
        _filtered = _lines.Where(Matches).ToList();
    }

    private bool Matches(string line)
    {
        if (string.IsNullOrEmpty(_levelFilter))
            return true;
        return ExtractLevel(line) == _levelFilter;
    }

    private static string ExtractLevel(string line)
    {
        var open = line.IndexOf('[');
        var close = open >= 0 ? line.IndexOf(']', open + 1) : -1;
        if (close <= open)
            return "";
        var token = line.Substring(open + 1, close - open - 1);
        // Only treat the bracketed token as a level if it actually is one, so a "[...]" elsewhere
        // in the message can't be mistaken for the level tag.
        return Loc.LogLevels.Contains(token) ? token : "";
    }

    private async Task Download()
    {
        var content = string.Join("\n", _lines);
        var name = $"rclonefilewatcher-log-{DateTime.Now:yyyyMMdd-HHmmss}.log";
        await JS.InvokeVoidAsync("rfwDownloadText", name, content);
    }

    private void Clear()
    {
        _lines.Clear();
        _filtered.Clear();
    }

    public void Dispose()
    {
        LogBuffer.MessageWritten -= OnMessage;
    }
}
