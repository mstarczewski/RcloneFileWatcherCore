@page "/rclone"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Collections.Generic
@using RcloneFileWatcherCore.Config
@using RcloneFileWatcherCore.DTO
@using RcloneFileWatcherCore.Enums
@using RcloneFileWatcherCore.Logic.Rclone
@implements IDisposable
@inject IConfigService ConfigService
@inject Loc L

<PageTitle>@L["nav.rclone"] — RcloneFileWatcher</PageTitle>

<h1>@L["nav.rclone"]</h1>

<p class="muted">@L["rcl.intro"]</p>

@{
    var cfg = ConfigService.Current;
}

<h2>@L["rcl.liveSyncTitle"]</h2>

@if (cfg.Path is null || cfg.Path.Count == 0)
{
    <p class="muted">@L["rcl.noPaths"]</p>
}
else
{
    @foreach (var path in cfg.Path)
    {
        <div class="path-card @(path.Enabled ? "" : "card-disabled")">
            <div class="path-card-head">
                <strong><code>@path.WatchingPath</code></strong>
                <span class="badge-group">
                    <span class="badge @(path.SyncMode == SyncMode.Managed ? "badge-accent" : "")">
                        @(path.SyncMode == SyncMode.Managed ? L["rcl.managed"] : L["rcl.script"])
                    </span>
                    <span class="badge @(path.Enabled ? "badge-ok" : "badge-off")">
                        @(path.Enabled ? L["rcl.enabled"] : L["rcl.disabled"])
                    </span>
                </span>
            </div>

            @if (path.SyncMode == SyncMode.Managed)
            {
                @if (path.RcloneCommand is not null)
                {
                    <pre class="cmd-line">@RcloneCommandBuilder.BuildPreview(path.RcloneCommand, IncludeFromFor(path))</pre>
                }
                else
                {
                    <p class="muted">@L["rcl.noCommand"]</p>
                }
            }
            else
            {
                <p class="muted">@L["rcl.scriptLabel"] <code>@(string.IsNullOrWhiteSpace(path.RcloneBatch) ? L["rcl.notSet"] : path.RcloneBatch)</code></p>
            }
        </div>
    }
}

<h2>@L["cfg.fullSyncTitle"]</h2>
<p class="muted">@FullSyncSchedule(cfg)</p>

@if (cfg.FullSyncMode == SyncMode.Managed)
{
    @if (cfg.FullSyncCommands is { Count: > 0 })
    {
        @foreach (var command in cfg.FullSyncCommands)
        {
            <div class="path-card @(command.Enabled ? "" : "card-disabled")">
                <div class="path-card-head">
                    <strong><code>@(string.IsNullOrWhiteSpace(command.Source) ? L["rcl.notSet"] : command.Source)</code></strong>
                    <span class="badge-group">
                        <span class="badge badge-accent">@L["rcl.managed"]</span>
                        <span class="badge @(command.Enabled ? "badge-ok" : "badge-off")">
                            @(command.Enabled ? L["rcl.enabled"] : L["rcl.disabled"])
                        </span>
                    </span>
                </div>
                <pre class="cmd-line">@RcloneCommandBuilder.BuildPreview(command, null)</pre>
            </div>
        }
    }
    else
    {
        <p class="muted">@L["rcl.fullSyncEmpty"]</p>
    }
}
else
{
    <div class="path-card">
        <div class="path-card-head">
            <strong><code>@(string.IsNullOrWhiteSpace(cfg.RunOneTimeFullStartupSyncBatch) ? L["rcl.notSet"] : cfg.RunOneTimeFullStartupSyncBatch)</code></strong>
            <span class="badge">@L["rcl.script"]</span>
        </div>
    </div>
}

@code {
    // What --include-from shows for a watched path: "-" (stdin) when the managed command pipes the
    // changed-files list, otherwise the on-disk files-from file - matching what the app runs.
    private static string IncludeFromFor(PathDTO p)
    {
        var c = p.RcloneCommand;
        return c != null && c.IncludeFrom && c.IncludeFromStdin ? "-" : p.RcloneFilesFromPath;
    }

    // Human-readable summary of when the full sync runs (daily time and/or at startup).
    private string FullSyncSchedule(ConfigDTO cfg)
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(cfg.RunStartupScriptEveryDayAt))
            parts.Add(L.F("rcl.dailyAt", cfg.RunStartupScriptEveryDayAt));
        if (cfg.RunOneTimeFullStartupSync)
            parts.Add(L["rcl.atStartup"]);
        return parts.Count > 0 ? string.Join(" · ", parts) : L["rcl.manualOnly"];
    }

    protected override void OnInitialized() => ConfigService.Changed += OnConfigChanged;

    private void OnConfigChanged(ConfigDTO config) => _ = InvokeAsync(StateHasChanged);

    public void Dispose() => ConfigService.Changed -= OnConfigChanged;
}
