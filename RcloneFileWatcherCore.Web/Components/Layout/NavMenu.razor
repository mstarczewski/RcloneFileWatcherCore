@inject RcloneFileWatcherCore.Web.Auth.IAuthService Auth
@inject Loc L

<div class="nav-brand">
    <span class="nav-logo">⟳</span> RcloneFileWatcher
</div>
<nav class="nav-menu">
    <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
        <Icon Name="dashboard" Class="nav-icon" /> @L["nav.dashboard"]
    </NavLink>
    <NavLink class="nav-item" href="config">
        <Icon Name="config" Class="nav-icon" /> @L["nav.config"]
    </NavLink>
    <NavLink class="nav-item" href="rclone">
        <Icon Name="cloud" Class="nav-icon" /> @L["nav.rclone"]
    </NavLink>
    <NavLink class="nav-item" href="logs">
        <Icon Name="logs" Class="nav-icon" /> @L["nav.logs"]
    </NavLink>
    <NavLink class="nav-item" href="notifications">
        <Icon Name="mail" Class="nav-icon" /> @L["nav.notifications"]
    </NavLink>
    <NavLink class="nav-item" href="security">
        <Icon Name="lock" Class="nav-icon" /> @L["nav.security"]
    </NavLink>
</nav>

@if (Auth.Enabled)
{
    <form method="post" action="/logout" class="nav-logout">
        <button type="submit" class="nav-item nav-logout-btn">
            <Icon Name="logout" Class="nav-icon" /> @L["nav.logout"]
        </button>
    </form>
}
