@inject RcloneFileWatcherCore.Web.Auth.IAuthService Auth
@inject Loc L

<div class="nav-brand">
    <span class="nav-logo">⟳</span> RcloneFileWatcher
</div>
<nav class="nav-menu">
    <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
        <span class="nav-icon">📊</span> @L["nav.dashboard"]
    </NavLink>
    <NavLink class="nav-item" href="config">
        <span class="nav-icon">⚙️</span> @L["nav.config"]
    </NavLink>
    <NavLink class="nav-item" href="rclone">
        <span class="nav-icon">☁️</span> @L["nav.rclone"]
    </NavLink>
    <NavLink class="nav-item" href="logs">
        <span class="nav-icon">📜</span> @L["nav.logs"]
    </NavLink>
    <NavLink class="nav-item" href="security">
        <span class="nav-icon">🔒</span> @L["nav.security"]
    </NavLink>
</nav>

@if (Auth.Enabled)
{
    <form method="post" action="/logout" class="nav-logout">
        <button type="submit" class="nav-item nav-logout-btn">
            <span class="nav-icon">🚪</span> @L["nav.logout"]
        </button>
    </form>
}
