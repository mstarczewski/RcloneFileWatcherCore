<?xml version="1.0" encoding="utf-8"?>
<!--
  Folder publish profile for deploying the web GUI to a Debian/Linux server.
  In Visual Studio: right-click RcloneFileWatcherCore.Web → Publish → pick "DebianFolder"
  → Publish. Then copy the WHOLE output folder (it includes wwwroot/ and locales/, required
  for CSS and translations) to the server (e.g. /opt/RcloneFileWatcherCoreWeb) and run it there.
  CLI equivalent:
    dotnet publish RcloneFileWatcherCore.Web/RcloneFileWatcherCore.Web.csproj -p:PublishProfile=DebianFolder
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>bin\Release\net8.0\publish\linux-x64\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <WebPublishMethod>FileSystem</WebPublishMethod>
    <_TargetId>Folder</_TargetId>
    <DeleteExistingFiles>true</DeleteExistingFiles>
    <ExcludeApp_Data>false</ExcludeApp_Data>
    <LaunchSiteAfterPublish>false</LaunchSiteAfterPublish>
    <TargetFramework>net8.0</TargetFramework>
    <RuntimeIdentifier>linux-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
  </PropertyGroup>
</Project>
