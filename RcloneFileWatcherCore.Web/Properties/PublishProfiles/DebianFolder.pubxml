<?xml version="1.0" encoding="utf-8"?>
<!--
  Folder publish profile for deploying the web GUI to a Debian/Linux server.
  In Visual Studio: right-click the RcloneFileWatcherCore.Web project → Publish → pick
  "DebianFolder" → click Publish. Then copy the WHOLE output folder (it contains wwwroot/
  and locales/, which are required for the CSS and translations) to the server, e.g.
  /opt/RcloneFileWatcherCoreWeb, and run it from there.
  CLI equivalent:
    dotnet publish RcloneFileWatcherCore.Web/RcloneFileWatcherCore.Web.csproj /p:PublishProfile=DebianFolder
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
    <TargetFramework>net8.0</TargetFramework>
    <RuntimeIdentifier>linux-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishDir>bin\Release\net8.0\publish\linux-x64\</PublishDir>
  </PropertyGroup>
</Project>
